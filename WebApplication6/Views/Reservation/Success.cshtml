@model WebApplication6.Models.ViewModels.ReservationSuccessVm
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

@{
    ViewData["Title"] = "Rezervasyon Tamamlandı";

    string Img(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return Url.Content("~/images/cars/default.jpg");
        url = url.Trim();

        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return url;

        if (url.StartsWith("/")) return url;

        return Url.Content("~/images/cars/" + url);
    }

    bool isIptal =
        string.Equals(Model.Durum, "İptal", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(Model.Durum, "Iptal", StringComparison.OrdinalIgnoreCase);
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="wrap">

    @* Mesajlar *@
    @if (TempData["CancelErr"] != null)
    {
        <div class="alert alert-danger" style="margin: 0 0 14px 0;">
            @TempData["CancelErr"]
        </div>
    }
    @if (TempData["CancelMsg"] != null)
    {
        <div class="alert alert-success" style="margin: 0 0 14px 0;">
            @TempData["CancelMsg"]
        </div>
    }

    <div class="card">
        <div class="head">
            <div class="tick @(isIptal ? "bad" : "ok")">
                <i class="fa-solid @(isIptal ? "fa-circle-xmark" : "fa-circle-check")"></i>
            </div>

            <div>
                <h1>@(isIptal ? "Rezervasyon iptal edildi" : "Rezervasyon tamamlandı")</h1>

                <div class="sub">Rezervasyon No: <b>#@Model.RezervasyonID</b></div>
                @if (!string.IsNullOrWhiteSpace(Model.MusteriAdSoyad))
                {
                    <div class="sub">Müşteri: <b>@Model.MusteriAdSoyad</b></div>
                }
            </div>
        </div>

        <div class="grid">
            <div class="car">
                <img src="@Img(Model.Arac?.ResimUrl)" alt="@Model.Arac?.Marka @Model.Arac?.Model" />
                <div class="car-title">@Model.Arac?.Marka @Model.Arac?.Model</div>
                <div class="meta">
                    <span class="pill">@Model.Arac?.Plaka</span>

                    @* Durum pill *@
                    @if (isIptal)
                    {
                        <span class="pill bad">İptal</span>
                    }
                    else
                    {
                        <span class="pill ok">@((Model.Durum ?? "Aktif"))</span>
                    }
                </div>
            </div>

            <div class="info">
                <div class="row">
                    <div class="k">Başlangıç</div>
                    <div class="v">@Model.Baslangic.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="row">
                    <div class="k">Kullanıcı</div>
                    <div class="v">@((Model.KullaniciAdSoyad ?? Model.MusteriAdSoyad) ?? "-")</div>
                </div>
                <div class="row">
                    <div class="k">Bitiş</div>
                    <div class="v">@Model.Bitis.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="row">
                    <div class="k">Toplam Gün</div>
                    <div class="v">@Model.ToplamGun gün</div>
                </div>
                <div class="row" style="border-bottom:none;">
                    <div class="k">Kalan Gün</div>
                    <div class="v">@Model.KalanGun gün</div>
                </div>

                <div class="actions">
                    <a class="btn ghost" asp-controller="Fleet" asp-action="Index">Yeni Rezervasyon</a>

                    @* İptal butonu sadece iptal değilse *@
                    @if (!isIptal)
                    {
                        <button type="button" class="btn danger"
                                data-bs-toggle="modal" data-bs-target="#cancelModal">
                            İptal Et
                        </button>
                    }

                    <a class="btn primary" asp-controller="Home" asp-action="Index">Anasayfa</a>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal (sayfanın sonunda dursa da olur) *@
@if (!isIptal)
{
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:14px;">
                <div class="modal-header">
                    <h5 class="modal-title" id="cancelModalLabel">Rezervasyon İptali</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body">
                    Oluşturduğunuz rezervasyonu sadece <b>2 saat</b> içinde iptal edebilirsiniz. Devam etmek istiyor musunuz?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>

                    <form asp-controller="Reservation" asp-action="Cancel" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.RezervasyonID" />
                        <button type="submit" class="btn btn-danger">İptal Et</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<style>
    :root {
        --bordeaux: #800000;
        --red: #D4002A;
        --bg: #f6f6f6;
        --border: #e5e7eb;
        --shadow: 0 18px 50px rgba(0,0,0,.12);
    }

    body {
        background: var(--bg);
    }

    .wrap {
        max-width: 980px;
        margin: 26px auto;
        padding: 0 16px;
    }

    .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .head {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 22px;
        border-bottom: 1px solid var(--border);
    }

    .tick {
        font-size: 44px;
    }

        .tick.ok {
            color: #16a34a;
        }

        .tick.bad {
            color: #ef4444;
        }


    h1 {
        margin: 0;
        font-size: 22px;
    }

    .sub {
        color: #6b7280;
        font-size: 13px;
        margin-top: 3px;
    }

    .grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 18px;
        padding: 18px;
    }

    .car img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #f3f4f6;
    }

    .car-title {
        font-weight: 900;
        margin-top: 10px;
        font-size: 16px;
    }

    .meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .pill {
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
    }

        .pill.ok {
            background: rgba(22,163,74,.08);
            border-color: rgba(22,163,74,.25);
            color: #15803d;
            font-weight: 900;
        }

        .pill.bad {
            background: rgba(239,68,68,.10);
            border-color: rgba(239,68,68,.28);
            color: #b91c1c;
            font-weight: 900;
        }

    .info {
        padding: 6px 4px;
    }

    .row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        gap: 10px;
    }

    .k {
        font-size: 12px;
        color: #6b7280;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .02em;
    }

    .v {
        font-size: 14px;
        font-weight: 900;
    }

    .actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding-top: 16px;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 900;
        border: 1px solid var(--border);
        background: #fff;
        color: #111;
        cursor: pointer;
    }

        .btn.primary {
            border: none;
            color: #fff;
            background: linear-gradient(45deg, var(--bordeaux), var(--red));
            box-shadow: 0 10px 26px rgba(128,0,0,.25);
        }

        .btn.ghost:hover {
            border-color: rgba(212,0,42,.35);
        }

        .btn.danger {
            border-color: rgba(239,68,68,.35);
            color: #b91c1c;
            background: #fff;
        }

            .btn.danger:hover {
                border-color: rgba(239,68,68,.6);
            }

    @@media (max-width:960px) {
        .grid {
            grid-template-columns: 1fr;
        }

        .actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
        }
    }
</style>
