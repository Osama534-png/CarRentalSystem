<style>
    :root {
        --primary-bordeaux: #800000;
        --primary-red: #D4002A;
        --light-bg: #f9f9f9;
        --text-dark: #333;
    }

    body { background-color: var(--light-bg); }

    .map-section { padding: 40px 5%; text-align: center; background-color: white; border-bottom: 1px solid #ddd; }
    .section-title { font-size: 32px; color: var(--primary-bordeaux); margin-bottom: 10px; font-weight: 900; }
    .section-subtitle { color: #666; margin-bottom: 40px; }

    .map-container {
        position: relative;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background-color: #eef;
    }

    .turkey-map-img { width: 100%; display: block; opacity: 0.95; }

    .car-marker {
        position: absolute;
        background-color: var(--primary-red);
        color: white;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        box-shadow: 0 0 0 2px rgba(212, 0, 42, 0.3);
        cursor: pointer;
        transform: translate(-50%, -50%);
        animation: bounce 2s infinite;
        z-index: 10;
    }

    .car-marker::after {
        content: attr(data-city);
        position: absolute;
        bottom: 35px;
        left: 50%;
        transform: translateX(-50%);
        background-color: #333;
        color: white;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: bold;
        white-space: nowrap;
        opacity: 0;
        transition: 0.3s;
        pointer-events: none;
        z-index: 20;
    }

    .car-marker:hover::after { opacity: 1; bottom: 40px; }
    .car-marker:hover {
        background-color: var(--primary-bordeaux);
        transform: translate(-50%, -50%) scale(1.2);
        z-index: 30;
    }

    /* Marker konumları */
    .loc-artvin { top: 15%; left: 85%; }
    .loc-istanbul { top: 18%; left: 23%; }
    .loc-istanbul-new { top: 14%; left: 20%; }
    .loc-ankara { top: 35%; left: 38%; }
    .loc-mugla { top: 75%; left: 18%; }
    .loc-kastamonu { top: 15%; left: 42%; }
    .loc-izmir { top: 52%; left: 10%; }
    .loc-antalya { top: 82%; left: 32%; }
    .loc-trabzon { top: 16%; left: 75%; }
    .loc-bursa { top: 25%; left: 18%; }
    .loc-adana { top: 68%; left: 54%; }
    .loc-gaziantep { top: 68%; left: 62%; }
    .loc-kayseri { top: 45%; left: 52%; }
    .loc-samsun { top: 12%; left: 55%; }
    .loc-diyarbakir { top: 55%; left: 78%; }

    @@keyframes bounce {
        0%, 20%, 50%, 80%, 100% { transform: translate(-50%, -50%) translateY(0); }
        40% { transform: translate(-50%, -50%) translateY(-10px); }
        60% { transform: translate(-50%, -50%) translateY(-5px); }
    }

    .offices-list {
        padding: 60px 10%;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
    }

    .office-card {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: 0.3s;
        border-top: 3px solid var(--primary-red);
        position: relative;
        overflow: hidden;
    }

    .office-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
    .office-card i.city-icon { font-size: 32px; color: #eee; position: absolute; top: 15px; right: 15px; }

    .office-card h3 { color: var(--primary-bordeaux); font-size: 18px; margin-bottom: 12px; font-weight: 800; }
    .office-detail { display: flex; align-items: flex-start; margin-bottom: 10px; color: #555; font-size: 13px; line-height: 1.4; }
    .office-detail i { color: var(--primary-red); margin-right: 8px; margin-top: 2px; width: 16px; font-size: 12px; }

    .btn-call {
        display: inline-block;
        margin-top: 10px;
        padding: 8px 18px;
        background-color: var(--primary-bordeaux);
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: bold;
        transition: 0.3s;
    }
    .btn-call:hover { background-color: var(--primary-red); }

    @@media (max-width: 768px) {
        .offices-list { padding: 28px 16px; }
    }
</style>
