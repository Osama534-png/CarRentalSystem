<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - OMA Rent A Car</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>


<body>
    <header class="oma-header">
        <div class="top-bar">
            <div class="logo">
                <a asp-controller="Home" asp-action="Index">
                    <img src="~/images/OMA.png" alt="OMA Logo">
                </a>
            </div>
      


            <nav class="oma-nav">
                <a asp-controller="Home" asp-action="Index">Anasayfa</a>
                <a asp-controller="Reservation" asp-action="Index">Rezervasyon</a>


                <a asp-controller="Fleet" asp-action="Index">Araç Filosu</a>
                <a asp-controller="Campaign" asp-action="Index">Kampanyalar</a>

                <a asp-controller="Offices" asp-action="Index">Ofisler</a>
                <a asp-controller="UserPanel" asp-action="Index">Hesabım</a>


            </nav>

            <div class="user-actions">
                <a asp-controller="Account" asp-action="Login" class="btn-login">Üye Girişi</a>
                <a asp-controller="Account" asp-action="Register" class="btn-register">Üye Olun</a>
            </div>
        </div>
    </header>
    @if (TempData["Success"] != null)
    {
        <div class="oma-alert oma-alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="oma-alert oma-alert-error">@TempData["Error"]</div>
    }
    <main>
        @RenderBody()
    </main>
 

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @* BURASI SADECE 1 KERE OLACAK *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

