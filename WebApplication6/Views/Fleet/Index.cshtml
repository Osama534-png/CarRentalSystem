@model List<WebApplication6.Models.vw_MusaitAraclar>

@{
    ViewData["Title"] = "Araç Filosu";

    int? alisSubeId = ViewBag.AlisSubeId != null ? (int?)Convert.ToInt32(ViewBag.AlisSubeId) : null;
    int? iadeSubeId = ViewBag.IadeSubeId != null ? (int?)Convert.ToInt32(ViewBag.IadeSubeId) : null;

    DateTime? baslangic = ViewBag.Baslangic != null ? (DateTime?)Convert.ToDateTime(ViewBag.Baslangic) : null;
    DateTime? bitis = ViewBag.Bitis != null ? (DateTime?)Convert.ToDateTime(ViewBag.Bitis) : null;

    string CarImg(string? resimUrl)
    {
        if (string.IsNullOrWhiteSpace(resimUrl))
            return Url.Content("~/images/cars/default.jpg");

        resimUrl = resimUrl.Trim();

        if (resimUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            resimUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return resimUrl;

        if (resimUrl.StartsWith("/"))
            return resimUrl;

        return Url.Content("~/images/cars/" + resimUrl);
    }
}
<form method="get" asp-controller="Fleet" asp-action="Index" class="fleet-search">
    <div class="fs-row">
        <div class="fs-field">
            <label>Marka</label>
            <input name="marka" value="@(ViewBag.Marka ?? "")" placeholder="BMW, Nissan, Toyota..." />
        </div>

        <div class="fs-field">
            <label>Model / Yıl</label>
            <input name="modelVeyaYil" value="@(ViewBag.ModelVeyaYil ?? "")" placeholder="Örn: Corolla veya 2024" />
        </div>

        <div class="fs-actions">
            <button type="submit" class="fs-btn">Ara</button>
            <a class="fs-btn ghost" asp-controller="Fleet" asp-action="Index">Temizle</a>
        </div>
    </div>
</form>

<style>
    .fleet-search{ max-width:1100px; margin:16px auto 18px; padding:0 14px; }
    .fs-row{
        background:#fff; border:1px solid rgba(0,0,0,.08);
        border-radius:14px; padding:14px;
        display:flex; gap:12px; align-items:end; flex-wrap:wrap;
        box-shadow:0 10px 26px rgba(0,0,0,.06);
    }
    .fs-field{ flex:1; min-width:220px; }
    .fs-field label{ display:block; font-size:12px; font-weight:800; color:#6b7280; margin-bottom:6px; }
    .fs-field input{
        width:100%; padding:10px 12px; border-radius:10px;
        border:1px solid rgba(0,0,0,.12); outline:none;
    }
    .fs-actions{ display:flex; gap:10px; }
    .fs-btn{
        border:none; padding:10px 16px; border-radius:999px;
        font-weight:900; cursor:pointer; text-decoration:none;
        background:#D4002A; color:#fff;
    }
    .fs-btn.ghost{ background:#fff; color:#111; border:1px solid rgba(0,0,0,.12); }
    @@media (max-width:700px){
        .fs-actions{ width:100%; }
        .fs-btn{ flex:1; text-align:center; }
    }
</style>

<div class="fleet-hero">
    <h1>Geniş Araç Filomuz</h1>
    <p>Müsait araçlar veritabanından otomatik listelenir.</p>
</div>

<div class="fleet-container">
    @foreach (var car in Model)
    {
        <div class="car-card">
            <div class="car-img-box">
                <img src="@CarImg(car.ResimUrl)" alt="@car.Marka @car.Model" />
            </div>

            <div class="car-details">
                <div class="car-title-row">
                    <h3>@car.Marka @car.Model</h3>
                    <span class="car-category">@car.KategoriAdi</span>
                </div>

                <div class="car-specs">
                    <div class="spec-item"><i class="fa-solid fa-calendar"></i> @car.Yil</div>
                    <div class="spec-item"><i class="fa-solid fa-location-dot"></i> @car.Sehir / @car.Ilce</div>
                    <div class="spec-item"><i class="fa-solid fa-building"></i> @car.SubeAdi</div>
                </div>

                <div class="car-price-row">
                    <div>
                        <div class="price-val">@($"{car.GunlukUcret:N0}") ₺</div>
                        <div class="price-label">Günlük</div>
                    </div>

                    <a class="btn-rent" href="@Url.Action("Create","Reservation", new {
                            aracId = car.AracID,
                            alisSubeId = alisSubeId,
                            iadeSubeId = iadeSubeId,
                            baslangic = baslangic,
                            bitis = bitis
                        })">
                        Hemen Kirala <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700;900&display=swap');

    :root {
        --primary-bordeaux: #800000;
        --primary-red: #D4002A;
        --light-bg: #f9f9f9;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Roboto', sans-serif;
    }

    body {
        background-color: var(--light-bg);
    }

    .fleet-hero {
        background-color: #222;
        color: white;
        padding: 60px 5%;
        text-align: center;
    }

    .fleet-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
    }

    .car-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: 0.3s;
        border: 1px solid #eee;
        display: flex;
        flex-direction: column;
    }

        .car-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            border-color: var(--primary-red);
        }

    .car-img-box {
        height: 220px;
        overflow: hidden;
        background-color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
    }

        .car-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 10px;
        }

    .car-details {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .car-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

        .car-title-row h3 {
            color: var(--primary-bordeaux);
            font-size: 20px;
        }

    .car-category {
        background-color: #eee;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: bold;
        color: #555;
        text-transform: uppercase;
    }

    .car-specs {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .spec-item {
        font-size: 13px;
        color: #666;
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 110px;
    }

        .spec-item i {
            color: var(--primary-red);
        }

    .car-price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
        gap: 12px;
    }

    .price-val {
        font-size: 22px;
        font-weight: 900;
        color: #222;
    }

    .price-label {
        font-size: 11px;
        color: #888;
    }

    .btn-rent {
        background-color: var(--primary-red);
        color: white;
        text-decoration: none;
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: bold;
        transition: 0.3s;
        white-space: nowrap;
    }

        .btn-rent:hover {
            background-color: var(--primary-bordeaux);
        }
</style>
